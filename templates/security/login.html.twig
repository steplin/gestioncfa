{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <article style="max-width: 420px; margin: auto;">

        <header>
            <h1>Connexion</h1>
            <p>Accès gestion heures</p>
        </header>

        {% if error %}
            <p role="alert">
                Identifiant ou mot de passe incorrect.
            </p>
        {% endif %}

        <form method="post">

            <label for="username">
                Identifiant
                <input
                    type="text"
                    id="username"
                    name="_username"
                    value="{{ last_username }}"
                    required
                    autofocus
                >
            </label>

            <label for="password">
                Mot de passe
                <input
                    type="password"
                    id="password"
                    name="_password"
                    required
                >
            </label>

            <input type="hidden"
                   name="_csrf_token"
                   value="{{ csrf_token('authenticate') }}">

            <button type="submit">
                Se connecter
            </button>
        </form>

        <footer>
            <small>
                En cas de difficulté, merci de vous rapprocher de l’équipe pédagogique.
            </small>
        </footer>

    </article>
{% endblock %}
